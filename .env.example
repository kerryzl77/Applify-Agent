# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-5.4

# Core app / auth
ENVIRONMENT=production
DEBUG=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ISSUER=
JWT_AUDIENCE=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Heroku will auto-populate DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/applify

# Redis (Heroku will auto-populate REDIS_URL)
REDIS_URL=redis://localhost:6379/0
RUN_QUEUE_NAME=applify:runs

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_URL=
ALLOWED_ORIGINS=http://localhost:5173

# Artifact storage
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_LOCAL_ROOT=uploads/artifacts
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Local development
POSTGRES_DB=applify
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

PORT=5000
